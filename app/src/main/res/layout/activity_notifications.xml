<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="true">

    <!-- FIXED TOP BACKGROUND -->
    <ImageView
        android:id="@+id/waveTop"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:src="@drawable/vector4"
        android:scaleType="fitXY"
        android:layout_alignParentTop="true"
        android:layout_marginTop="-23dp"
        android:importantForAccessibility="no"/>

    <!-- FIXED HEADER SECTION -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="20dp"
        android:layout_marginStart="20dp"
        android:src="@drawable/ic_back"
        app:tint="#FFFFFF"
        android:clickable="true"
        android:focusable="true"
        android:elevation="5dp"
        android:contentDescription="Back"/>

    <TextView
        android:id="@+id/titleNotif"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Notifications"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:fontFamily="@font/dm_sans_bold"
        android:layout_marginStart="24dp"
        android:layout_marginTop="50dp"
        android:elevation="5dp"/>

    <!-- NOTIFICATION LIST -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvNotifications"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/waveTop"
        android:layout_marginTop="15dp"
        android:paddingHorizontal="20dp"
        android:clipToPadding="false"
        android:paddingBottom="40dp"
        android:layout_marginBottom="61dp"
        tools:listitem="@layout/item_notification"/>

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No new invitations"
        android:textColor="#888888"
        android:layout_centerInParent="true"
        android:visibility="gone"/>

    <!-- 🔥 BOTTOM WAVE -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:layout_alignParentBottom="true"
        android:src="@drawable/vector_2"
        android:scaleType="fitXY"
        android:importantForAccessibility="no"/>

    <!-- 🔴 BOTTOM RECTANGLE -->
    <View
        android:layout_width="match_parent"
        android:layout_height="61dp"
        android:layout_alignParentBottom="true"
        android:background="#78182C"/>

    <!-- 🔥 BOTTOM NAV ICONS -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- HOME -->
        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_home"
                android:scaleType="fitCenter"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- TRIPS -->
        <LinearLayout
            android:id="@+id/navTrips"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_luggage"
                android:scaleType="fitCenter"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Past Trips"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- NOTIFICATION -->
        <LinearLayout
            android:id="@+id/navNotif"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_alerts"
                android:scaleType="fitCenter"
                app:tint="#F3DCE1"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alerts"
                android:textColor="#F3DCE1"
                android:textSize="11sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- PROFILE -->
        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_profile"
                android:scaleType="fitCenter"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>