<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1C0808"
    android:padding="24dp">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add Checklist Item"
        android:textColor="#FFFFFF"
        android:fontFamily="@font/dm_sans_bold"
        android:textSize="18sp"
        android:layout_marginBottom="20dp" />

    <!-- Item Name Label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Item Name"
        android:textColor="#FF2D55"
        android:fontFamily="@font/dm_sans_medium"
        android:textSize="12sp"
        android:layout_marginBottom="4dp" />

    <!-- Item Name: AutoCompleteTextView (dropdown + free type) -->
    <AutoCompleteTextView
        android:id="@+id/actvItemName"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/dialog_input_background"
        android:hint="Select or type item name"
        android:textColorHint="#555555"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:fontFamily="@font/dm_sans_regular"
        android:paddingStart="14dp"
        android:paddingEnd="36dp"
        android:completionThreshold="1"
        android:dropDownHeight="wrap_content"
        android:popupBackground="#2A0808"
        android:layout_marginBottom="14dp"
        android:singleLine="true" />

    <!-- Quantity Label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Quantity"
        android:textColor="#FF2D55"
        android:fontFamily="@font/dm_sans_medium"
        android:textSize="12sp"
        android:layout_marginBottom="4dp" />

    <!-- Quantity input -->
    <EditText
        android:id="@+id/etQuantity"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/dialog_input_background"
        android:hint="1"
        android:textColorHint="#555555"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:fontFamily="@font/dm_sans_regular"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:inputType="number"
        android:layout_marginBottom="14dp" />

    <!-- Category Label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Category"
        android:textColor="#FF2D55"
        android:fontFamily="@font/dm_sans_medium"
        android:textSize="12sp"
        android:layout_marginBottom="4dp" />

    <!-- Category Spinner wrapped in styled container -->
    <Spinner
        android:id="@+id/spinnerCategory"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/dialog_spinner_background"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:fontFamily="@font/dm_sans_regular"
        android:layout_marginBottom="24dp"
        android:popupBackground="#2A0808" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#3A1010"
        android:layout_marginBottom="16dp" />

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:weightSum="2">

        <TextView
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Cancel"
            android:textColor="#888888"
            android:fontFamily="@font/dm_sans_medium"
            android:textSize="14sp"
            android:background="@drawable/dialog_btn_outline"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnAdd"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Add Item"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/dm_sans_bold"
            android:textSize="14sp"
            android:background="@drawable/dialog_btn_primary"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</LinearLayout>