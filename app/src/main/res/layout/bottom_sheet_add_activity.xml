<?xml version="1.0" encoding="utf-8"?>
<!--
    NEW FILE: app/src/main/res/layout/bottom_sheet_add_activity.xml
    Add Activity bottom sheet — opens when FAB is tapped.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1A1A1A"
    android:paddingHorizontal="24dp"
    android:paddingTop="12dp"
    android:paddingBottom="36dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="#555555" />

    <!-- Sheet title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/dm_sans_bold"
        android:text="Add Activity"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:layout_marginBottom="20dp" />

    <!-- DAY label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/dm_sans_bold"
        android:text="Day"
        android:textColor="#FF2D55"
        android:textSize="13sp"
        android:layout_marginBottom="6dp" />

    <!-- Day Spinner -->
    <Spinner
        android:id="@+id/spinnerDay"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/input_bg"
        android:paddingHorizontal="12dp"
        android:popupBackground="#1E1E1E" />

    <!-- TIME label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/dm_sans_bold"
        android:text="Time"
        android:textColor="#FF2D55"
        android:textSize="13sp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="6dp" />

    <!-- Time field — tap opens TimePicker -->
    <EditText
        android:id="@+id/etTime"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/input_bg"
        android:hint="Tap to pick a time"
        android:textColor="#FFFFFF"
        android:textColorHint="#888888"
        android:textSize="15sp"
        android:padding="12dp"
        android:focusable="false"
        android:clickable="true"
        android:cursorVisible="false"
        android:inputType="none" />

    <!-- ACTIVITY label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/dm_sans_bold"
        android:text="Activity"
        android:textColor="#FF2D55"
        android:textSize="13sp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/etActivityTitle"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/input_bg"
        android:hint="e.g. Beach Walk at Calangute"
        android:textColor="#FFFFFF"
        android:textColorHint="#888888"
        android:textSize="15sp"
        android:padding="12dp"
        android:inputType="textCapSentences" />

    <!-- LOCATION label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/dm_sans_bold"
        android:text="Location (optional)"
        android:textColor="#FF2D55"
        android:textSize="13sp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/etActivityLocation"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/input_bg"
        android:hint="e.g. Baga Beach"
        android:textColor="#FFFFFF"
        android:textColorHint="#888888"
        android:textSize="15sp"
        android:padding="12dp"
        android:inputType="textCapWords" />

    <!-- ADD BUTTON -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnAddActivity"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/btn_red"
        android:fontFamily="@font/dm_sans_bold"
        android:text="Add Activity"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="16sp" />

</LinearLayout>