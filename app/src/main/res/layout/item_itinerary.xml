<?xml version="1.0" encoding="utf-8"?>
<!--
    REPLACE: app/src/main/res/layout/item_itinerary.xml
    Matches Figma exactly — dark maroon card, pink time,
    white bold title, pink location, × delete top-right
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="#2A0A0A"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Delete button — top right -->
        <ImageView
            android:id="@+id/btnDelete"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:src="@drawable/ic_close"
            app:tint="#AA4466"
            android:contentDescription="Delete"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <!-- Content block (to the left of delete button) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@id/btnDelete"
            android:orientation="vertical">

            <!-- Time: "09:00 AM" in pink -->
            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/dm_sans_bold"
                android:text="09:00 AM"
                android:textColor="#FF2D55"
                android:textSize="12sp" />

            <!-- Activity title in white bold -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/dm_sans_bold"
                android:text="Arrival &amp; Hotel Check-in"
                android:textColor="#FFFFFF"
                android:textSize="15sp" />

            <!-- Location row — hidden if empty -->
            <LinearLayout
                android:id="@+id/layoutLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:contentDescription="Location"
                    android:src="@drawable/ic_location"
                    app:tint="#F3DCE1" />

                <TextView
                    android:id="@+id/tvLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:fontFamily="@font/dm_sans_medium"
                    android:text="Baga Beach Resort"
                    android:textColor="#F3DCE1"
                    android:textSize="13sp" />
            </LinearLayout>

        </LinearLayout>

    </RelativeLayout>
</androidx.cardview.widget.CardView>