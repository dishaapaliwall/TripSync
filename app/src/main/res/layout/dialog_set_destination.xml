<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1C0808"
    android:padding="24dp">

    <ImageView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_location"
        android:tint="#FF2D55"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Set Meeting Point"
        android:textColor="#FFFFFF"
        android:fontFamily="@font/dm_sans_bold"
        android:textSize="20sp"
        android:gravity="center"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enter a place or use your current location."
        android:textColor="#BBBBBB"
        android:fontFamily="@font/dm_sans_regular"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="20dp" />

    <EditText
        android:id="@+id/etDestinationName"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:background="@drawable/dialog_input_background"
        android:hint="e.g. Baga Beach, Airport"
        android:textColorHint="#555555"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:fontFamily="@font/dm_sans_regular"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:singleLine="true"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:id="@+id/btnCurrentLocation"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/dialog_btn_outline"
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_location"
            android:tint="#FF2D55"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Use Current Location"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/dm_sans_medium"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:weightSum="2">

        <TextView
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Cancel"
            android:textColor="#888888"
            android:fontFamily="@font/dm_sans_medium"
            android:textSize="14sp"
            android:background="@drawable/dialog_btn_outline"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnSet"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Set Point"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/dm_sans_bold"
            android:textSize="14sp"
            android:background="@drawable/dialog_btn_primary"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</LinearLayout>