<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="20dp">

    <!-- Plane -->
    <ImageView
        android:id="@+id/planeIcon"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/ic_airplane"
        app:tint="#8B1C2D"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="30dp"
        android:rotation="20"
        android:importantForAccessibility="no"/>

    <!-- Title -->
    <TextView
        android:id="@+id/logo"
        android:text="@string/welcome_back"
        android:textColor="#8B1C2D"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_below="@id/planeIcon"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="1dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- Subtitle -->
    <TextView
        android:id="@+id/subtitle"
        android:text="@string/sign_in_subtitle"
        android:textColor="#8B1C2D"
        android:textSize="14sp"
        android:layout_below="@id/logo"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="30dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- Email Section -->
    <TextView
        android:id="@+id/emailLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/subtitle"
        android:layout_marginTop="10dp"
        android:layout_marginStart="8dp"
        android:text="@string/email"
        android:textColor="#FF2D55"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/email"
        android:hint="@string/enter_your_email"
        android:background="@drawable/input_bg"
        android:textColor="#FFFFFF"
        android:textColorHint="#888888"
        android:layout_below="@id/emailLabel"
        android:layout_marginTop="8dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:padding="12dp"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:inputType="textEmailAddress"
        android:autofillHints="emailAddress"/>

    <!-- Password Section -->
    <TextView
        android:id="@+id/passwordLabel"
        android:text="@string/password"
        android:textColor="#FF2D55"
        android:textSize="14sp"
        android:layout_below="@id/email"
        android:layout_marginTop="20dp"
        android:layout_marginStart="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <EditText
        android:id="@+id/password"
        android:hint="@string/enter_your_password"
        android:textColor="#FFFFFF"
        android:textColorHint="#888888"
        android:background="@drawable/input_bg"
        android:layout_below="@id/passwordLabel"
        android:layout_marginTop="8dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:padding="12dp"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:inputType="textPassword"
        android:autofillHints="password"/>

    <TextView
        android:id="@+id/forgotPassword"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/forgot_password"
        android:textColor="#FF2D55"
        android:textSize="14sp"
        android:layout_below="@id/password"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="0dp"
        android:layout_marginEnd="15dp"
        android:clickable="true"
        android:focusable="true"
        android:padding="4dp"/>

    <!-- Login Button -->
    <Button
        android:id="@+id/loginButton"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_below="@id/forgotPassword"
        android:layout_marginTop="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:backgroundTint="#78182C"
        android:text="@string/log_in"
        android:textColor="#FFFFFF" />

    <!-- OR Divider -->
    <LinearLayout
        android:id="@+id/orSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/loginButton"
        android:layout_marginTop="3dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:gravity="center"
        android:orientation="horizontal">

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="#44FF2D55" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:text="@string/or"
            android:textColor="#FF2D55"
            android:textSize="12sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="#44FF2D55" />
    </LinearLayout>

    <!-- Google Button -->
    <Button
        android:id="@+id/googleButton"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_below="@id/orSection"
        android:layout_marginTop="3dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:backgroundTint="#1E1E1E"
        android:text="@string/continue_with_google"
        android:textAllCaps="false"
        android:textColor="#D12B4D" />

    <!-- Sign Up Text -->
    <TextView
        android:id="@+id/signUpText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/googleButton"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="3dp"
        android:clickable="true"
        android:focusable="true"
        android:text="@string/dont_have_account_signup"
        android:textColor="#FF2D55"
        android:textSize="13sp" />

    <!-- Bottom Wave -->
    <ImageView
        android:id="@+id/wave"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_alignParentBottom="true"
        android:src="@drawable/vector_2"
        android:scaleType="fitXY"
        android:importantForAccessibility="no"/>

</RelativeLayout>