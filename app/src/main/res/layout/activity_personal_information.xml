<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="true">

    <!-- FIXED TOP WAVE -->
    <ImageView
        android:id="@+id/waveTop"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:src="@drawable/vector3"
        android:scaleType="fitXY"
        android:layout_alignParentTop="true"
        android:importantForAccessibility="no"/>

    <!-- FIXED HEADER SECTION -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="20dp"
        android:layout_marginStart="20dp"
        android:src="@drawable/ic_back"
        app:tint="@color/black"
        android:clickable="true"
        android:focusable="true"
        android:elevation="5dp"
        android:contentDescription="@string/back"/>

    <TextView
        android:id="@+id/titleInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/personal_info_title"
        android:textColor="@color/black"
        android:textSize="27sp"
        android:textStyle="bold"
        android:fontFamily="@font/dm_sans_bold"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="45dp"
        android:elevation="5dp"/>

    <!-- SCROLLABLE FORM SECTION -->
    <ScrollView
        android:id="@+id/formScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/waveTop"
        android:paddingHorizontal="24dp"
        android:clipToPadding="false"
        android:paddingBottom="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Full Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/full_name"
                android:textColor="#FF2D55"
                android:layout_marginTop="20dp"
                android:layout_marginStart="4dp"
                android:textSize="14sp"
                android:fontFamily="@font/dm_sans_bold"/>
            <EditText
                android:id="@+id/editName"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/input_bg"
                android:paddingHorizontal="15dp"
                android:layout_marginTop="8dp"
                android:textColor="#FFFFFF"
                android:hint="@string/full_name"
                android:textColorHint="#44FFFFFF"
                android:inputType="textPersonName"
                android:importantForAutofill="no" />

            <!-- Email -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/email"
                android:textColor="#FF2D55"
                android:layout_marginTop="20dp"
                android:layout_marginStart="4dp"
                android:textSize="14sp"
                android:fontFamily="@font/dm_sans_bold"/>
            <EditText
                android:id="@+id/editEmail"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/input_bg"
                android:paddingHorizontal="15dp"
                android:layout_marginTop="8dp"
                android:textColor="#888888"
                android:hint="@string/email"
                android:textColorHint="#44FFFFFF"
                android:enabled="false"
                android:inputType="textEmailAddress"
                android:importantForAutofill="no" />

            <!-- Phone Number -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/phone_number"
                android:textColor="#FF2D55"
                android:layout_marginTop="20dp"
                android:layout_marginStart="4dp"
                android:textSize="14sp"
                android:fontFamily="@font/dm_sans_bold"/>
            <EditText
                android:id="@+id/editPhone"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/input_bg"
                android:paddingHorizontal="15dp"
                android:layout_marginTop="8dp"
                android:textColor="#FFFFFF"
                android:hint="@string/phone_number"
                android:inputType="phone"
                android:textColorHint="#44FFFFFF"
                android:importantForAutofill="no" />

            <!-- Date of Birth -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/date_of_birth"
                android:textColor="#FF2D55"
                android:layout_marginTop="20dp"
                android:layout_marginStart="4dp"
                android:textSize="14sp"
                android:fontFamily="@font/dm_sans_bold"/>
            <EditText
                android:id="@+id/editDOB"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/input_bg"
                android:paddingHorizontal="15dp"
                android:layout_marginTop="8dp"
                android:textColor="#FFFFFF"
                android:hint="@string/dob_hint"
                android:textColorHint="#44FFFFFF"
                android:focusable="false"
                android:clickable="true"
                android:inputType="none"
                android:importantForAutofill="no" />

            <!-- Location (Locked, updated via Country/Region screen) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/location"
                android:textColor="#FF2D55"
                android:layout_marginTop="20dp"
                android:layout_marginStart="4dp"
                android:textSize="14sp"
                android:fontFamily="@font/dm_sans_bold"/>
            <EditText
                android:id="@+id/editLocation"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/input_bg"
                android:paddingHorizontal="15dp"
                android:layout_marginTop="8dp"
                android:textColor="#888888"
                android:hint="@string/location"
                android:textColorHint="#44FFFFFF"
                android:enabled="false"
                android:focusable="false"
                android:inputType="none"
                android:importantForAutofill="no" />

            <!-- Gender -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/gender"
                android:textColor="#FF2D55"
                android:layout_marginTop="20dp"
                android:layout_marginStart="4dp"
                android:textSize="14sp"
                android:fontFamily="@font/dm_sans_bold"/>
            <Spinner
                android:id="@+id/spinGender"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_bg"
                android:paddingStart="4dp"
                android:paddingEnd="15dp"
                android:spinnerMode="dropdown"
                tools:listitem="@android:layout/simple_list_item_1" />

            <!-- Save Button -->
            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="@string/save_changes"
                android:backgroundTint="#78182C"
                android:textColor="#FFFFFF"
                android:layout_marginTop="40dp"
                android:fontFamily="@font/dm_sans_bold"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:layout_marginBottom="40dp"/>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>