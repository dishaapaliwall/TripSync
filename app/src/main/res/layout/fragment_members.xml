<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#64191F"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trip Invite Code"
                        android:textColor="#A0A0A0"
                        android:textSize="12sp"
                        android:fontFamily="@font/dm_sans_medium"/>

                    <TextView
                        android:id="@+id/tvTripCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tvLabel"
                        android:layout_marginTop="4dp"
                        android:text="TRIP-GOA4"
                        android:textColor="#FFFFFF"
                        android:textSize="28sp"
                        android:fontFamily="@font/dm_sans_bold"/>

                    <TextView
                        android:id="@+id/btnCopyCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/option_bg"
                        android:backgroundTint="#FFFFFF"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:text="Copy Code"
                        android:textColor="#000000"
                        android:textSize="12sp"
                        android:fontFamily="@font/dm_sans_bold"
                        android:clickable="true"
                        android:focusable="true"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Trip Members"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:fontFamily="@font/dm_sans_bold"/>

                <TextView
                    android:id="@+id/tvMemberCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/badge_bg"
                    android:backgroundTint="#FF2D55"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="0 Members"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:fontFamily="@font/dm_sans_bold"/>

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMembers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_member" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Trip Documents"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="@font/dm_sans_bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Upload docs for each member above:"
                android:textColor="#888888"
                android:textSize="12sp"
                android:fontFamily="@font/dm_sans_regular"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:columnCount="2">

                <!-- Tickets -->
                <LinearLayout
                    android:id="@+id/btnUploadFlight"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/dashed_border_bg"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_tickets"
                        app:tint="#FFFFFF" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Tickets"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:fontFamily="@font/dm_sans_medium"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+ Upload"
                        android:textColor="#888888"
                        android:textSize="10sp"/>
                </LinearLayout>

                <!-- Hotel Booking -->
                <LinearLayout
                    android:id="@+id/btnUploadHotel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/dashed_border_bg"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_hotel"
                        app:tint="#FFFFFF" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Hotel Booking"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:fontFamily="@font/dm_sans_medium"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+ Upload"
                        android:textColor="#888888"
                        android:textSize="10sp"/>
                </LinearLayout>

                <!-- ID Copies -->
                <LinearLayout
                    android:id="@+id/btnUploadID"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/dashed_border_bg"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_id_card"
                        app:tint="#FFFFFF" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="ID Copies"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:fontFamily="@font/dm_sans_medium"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+ Upload"
                        android:textColor="#888888"
                        android:textSize="10sp"/>
                </LinearLayout>

                <!-- Travel Insurance -->
                <LinearLayout
                    android:id="@+id/btnUploadInsurance"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/dashed_border_bg"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:clickable="true"
                    android:focusable="true">
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_insurance"
                        app:tint="#FFFFFF" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Travel Insurance"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:fontFamily="@font/dm_sans_medium"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+ Upload"
                        android:textColor="#888888"
                        android:textSize="10sp"/>
                </LinearLayout>
            </GridLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="100dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</RelativeLayout>