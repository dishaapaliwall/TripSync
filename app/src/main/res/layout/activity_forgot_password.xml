<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="20dp"
    android:fitsSystemWindows="true">

    <!-- Back Button -->
    <ImageView
        android:id="@+id/backBtn"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_back"
        app:tint="#8B1C2D"
        android:padding="8dp"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Back" />

    <!-- Plane Icon -->
    <ImageView
        android:id="@+id/planeIcon"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/ic_airplane"
        app:tint="#8B1C2D"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="30dp"
        android:rotation="20"
        android:importantForAccessibility="no"/>

    <!-- Title -->
    <TextView
        android:id="@+id/title"
        android:text="Forgot Password"
        android:textColor="#8B1C2D"
        android:textSize="26sp"
        android:textStyle="bold"
        android:fontFamily="@font/dm_sans_bold"
        android:layout_below="@id/planeIcon"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="1dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- Subtitle -->
    <TextView
        android:id="@+id/subtitle"
        android:text="Enter your email to receive a reset link"
        android:textColor="#8B1C2D"
        android:textSize="14sp"
        android:layout_below="@id/title"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="30dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- Email Label -->
    <TextView
        android:id="@+id/emailLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/subtitle"
        android:layout_marginTop="10dp"
        android:layout_marginStart="8dp"
        android:text="@string/email"
        android:textColor="#FF2D55"
        android:textSize="14sp" />

    <!-- Email Input -->
    <EditText
        android:id="@+id/email"
        android:hint="@string/enter_your_email"
        android:background="@drawable/input_bg"
        android:textColor="#FFFFFF"
        android:textColorHint="#888888"
        android:layout_below="@id/emailLabel"
        android:layout_marginTop="8dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:padding="12dp"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:inputType="textEmailAddress"
        android:autofillHints="emailAddress"/>

    <!-- Reset Button -->
    <Button
        android:id="@+id/resetButton"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_below="@id/email"
        android:layout_marginTop="15dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:backgroundTint="#78182C"
        android:text="Send Reset Link"
        android:textColor="#FFFFFF" />

    <!-- Bottom Wave -->
    <ImageView
        android:id="@+id/wave"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_alignParentBottom="true"
        android:src="@drawable/vector_2"
        android:scaleType="fitXY"
        android:importantForAccessibility="no"
        android:layout_margin="-20dp"/>

</RelativeLayout>