<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="true">

    <!-- FIXED TOP WAVE -->
    <ImageView
        android:id="@+id/waveTop"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:src="@drawable/vector3"
        android:scaleType="fitXY"
        android:layout_alignParentTop="true"
        android:importantForAccessibility="no"/>

    <!-- FIXED HEADER SECTION -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="20dp"
        android:layout_marginStart="20dp"
        android:src="@drawable/ic_back"
        app:tint="@color/black"
        android:clickable="true"
        android:focusable="true"
        android:elevation="5dp"
        android:contentDescription="Back"/>

    <TextView
        android:id="@+id/titleSecurity"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Security &amp; Privacy"
        android:textColor="@color/black"
        android:textSize="27sp"
        android:textStyle="bold"
        android:fontFamily="@font/dm_sans_bold"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="45dp"
        android:elevation="5dp"/>

    <!-- SCROLLABLE CONTENT SECTION -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/waveTop"
        android:paddingHorizontal="24dp"
        android:clipToPadding="false"
        android:paddingBottom="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stay in control of your account access and security preferences."
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/dm_sans_medium"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFFFFF"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"/>

            <!-- Privacy Section with Toggle -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/txtPrivacy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Privacy"
                    android:textColor="#FF2D55"
                    android:textSize="18sp"
                    android:fontFamily="@font/dm_sans_bold"/>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchPrivateProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:thumbTint="#FF2D55"
                    app:trackTint="#66FF2D55"
                    android:checked="false"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/txtPrivacy"
                    android:text="Private Profile: Mera profile sirf friends ko dikhe."
                    android:textColor="#CCCCCC"
                    android:textSize="13sp"
                    android:layout_marginTop="5dp"
                    android:fontFamily="@font/dm_sans_medium"/>
            </RelativeLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="At TripSync, we take your privacy very seriously. Therefore we would like to inform you what data we collect, as well as when and how we deal with your personal information. To learn more, read our Privacy Policy and Cookies Policy. If you have any questions, don't hesitate to contact us."
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginTop="15dp"
                android:fontFamily="@font/dm_sans_medium"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFFFFF"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"/>

            <!-- Delete Account Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Delete account"
                android:textColor="#FF2D55"
                android:textSize="18sp"
                android:fontFamily="@font/dm_sans_bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Permanently delete your account and data. You can recover your account by logging in within 30 days."
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/dm_sans_medium"/>

            <!-- Delete Button Styled Like TripSync -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnDeleteAccount"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#2A0A0A"
                android:layout_marginTop="25dp"
                android:layout_marginBottom="40dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_back"
                        android:rotation="180"
                        app:tint="#FF2D55"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Delete your account"
                        android:textColor="#FF2D55"
                        android:textSize="16sp"
                        android:fontFamily="@font/dm_sans_bold"
                        android:layout_marginStart="10dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>