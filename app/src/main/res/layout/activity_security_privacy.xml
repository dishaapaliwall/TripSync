<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="true">

    <!-- FIXED TOP WAVE -->
    <ImageView
        android:id="@+id/waveTop"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:src="@drawable/vector3"
        android:scaleType="fitXY"
        android:layout_alignParentTop="true"
        android:importantForAccessibility="no"/>

    <!-- FIXED HEADER SECTION -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="20dp"
        android:layout_marginStart="20dp"
        android:src="@drawable/ic_back"
        app:tint="@color/black"
        android:clickable="true"
        android:focusable="true"
        android:elevation="5dp"
        android:contentDescription="Back"/>

    <TextView
        android:id="@+id/titleSecurity"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Security &amp; Privacy"
        android:textColor="@color/black"
        android:textSize="27sp"
        android:textStyle="bold"
        android:fontFamily="@font/dm_sans_bold"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="45dp"
        android:elevation="5dp"/>

    <!-- SCROLLABLE CONTENT SECTION -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/waveTop"
        android:paddingHorizontal="24dp"
        android:clipToPadding="false"
        android:paddingBottom="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stay in control of your account access and security preferences."
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/dm_sans_medium"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFFFFF"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"/>

            <!-- Deactivation (Temporary) Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Deactivate Account"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:fontFamily="@font/dm_sans_bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Temporarily disable your account. You can return anytime by simply logging back in."
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/dm_sans_medium"/>

            <androidx.cardview.widget.CardView
                android:id="@+id/btnDeactivateAccount"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#1A1A1A"
                android:layout_marginTop="15dp"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Deactivate Temporarily"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:fontFamily="@font/dm_sans_bold"/>
            </androidx.cardview.widget.CardView>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFFFFF"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="25dp"/>

            <!-- Permanent Deletion Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Delete Account Permanently"
                android:textColor="#FF2D55"
                android:textSize="18sp"
                android:fontFamily="@font/dm_sans_bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Warning: This will immediately erase all your data, trips, and settings. This action cannot be undone."
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/dm_sans_medium"/>

            <androidx.cardview.widget.CardView
                android:id="@+id/btnDeleteAccountPermanent"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#2A0A0A"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="40dp"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Delete Permanently"
                    android:textColor="#FF2D55"
                    android:textSize="15sp"
                    android:fontFamily="@font/dm_sans_bold"/>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</RelativeLayout>