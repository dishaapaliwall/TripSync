<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="true">

    <!-- 🔙 BACK BUTTON -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:padding="4dp"
        android:src="@drawable/ic_back"
        app:tint="#FF2D55" />

    <!-- 📝 TITLE -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="40dp"
        android:fontFamily="@font/dm_sans_bold"
        android:text="Create Trip"
        android:textColor="#FF2D55"
        android:textSize="27sp"
        android:textStyle="bold" />

    <!-- 📋 FORM SCROLL -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/tvTitle"
        android:layout_marginTop="20dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="200dp">

            <!-- TRIP NAME -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trip Name"
                android:textColor="#FF2D55"
                android:textSize="14sp"
                android:layout_marginStart="8dp" />

            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/input_bg"
                android:hint="e.g. Goa Trip 2026"
                android:inputType="textCapWords"
                android:padding="12dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:textSize="16sp" />

            <!-- DESTINATION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Destination"
                android:textColor="#FF2D55"
                android:textSize="14sp"
                android:layout_marginStart="8dp" />

            <EditText
                android:id="@+id/etLocation"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/input_bg"
                android:hint="Enter Destination"
                android:inputType="textPostalAddress"
                android:padding="12dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:textSize="16sp" />

            <!-- DATES -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Dates"
                android:textColor="#FF2D55"
                android:textSize="14sp"
                android:layout_marginStart="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginHorizontal="8dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etStart"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:background="@drawable/input_bg"
                    android:focusable="false"
                    android:hint="Start Date"
                    android:padding="12dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#888888"
                    android:textSize="16sp" />

                <View
                    android:layout_width="12dp"
                    android:layout_height="0dp" />

                <EditText
                    android:id="@+id/etEnd"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:background="@drawable/input_bg"
                    android:focusable="false"
                    android:hint="End Date"
                    android:padding="12dp"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#888888"
                    android:textSize="16sp" />
            </LinearLayout>

            <!-- BUDGET -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Budget ( ₹ )"
                android:textColor="#FF2D55"
                android:textSize="14sp"
                android:layout_marginStart="8dp" />

            <EditText
                android:id="@+id/etBudget"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/input_bg"
                android:hint="Enter total budget"
                android:inputType="number"
                android:padding="12dp"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:textSize="16sp" />

            <!-- INVITE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Invite Members"
                android:textColor="#FF2D55"
                android:textSize="14sp"
                android:layout_marginStart="8dp" />

            <RelativeLayout
                android:id="@+id/btnSelectFriends"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/input_bg"
                android:paddingHorizontal="12dp">

                <TextView
                    android:id="@+id/tvSelectedCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="Select Friends"
                    android:textColor="#888888"
                    android:textSize="16sp" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_friends"
                    app:tint="#888888" />
            </RelativeLayout>

            <!-- 🔘 CREATE BUTTON -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnCreate"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="30dp"
                android:layout_marginHorizontal="8dp"
                android:background="@drawable/btn_red"
                android:text="Create Trip"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:fontFamily="@font/dm_sans_bold"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>

    <!-- 🌊 BOTTOM WAVE (Declared last to stay on top) -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_alignParentBottom="true"
        android:scaleType="fitXY"
        android:src="@drawable/vector_2"
        android:elevation="0dp" />

</RelativeLayout>
